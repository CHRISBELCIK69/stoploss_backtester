if __name__ == '__main__':
    # Generate sample data for demonstration
    np.random.seed(42)
    n = 500
    dates = pd.date_range('2023-01-01', periods=n, freq='B')
    close = 100 + np.cumsum(np.random.randn(n) * 0.5)
    high = close + np.abs(np.random.randn(n) * 0.3)
    low = close - np.abs(np.random.randn(n) * 0.3)
    open_ = close + np.random.randn(n) * 0.1
    volume = np.random.randint(1000, 10000, n).astype(float)

    df = pd.DataFrame({
        'open': open_, 'high': high, 'low': low,
        'close': close, 'volume': volume
    }, index=dates)

    print("=" * 60)
    print("TSM Stop Loss Strategies - Demo")
    print("=" * 60)

    # --- 1. StdDev Trailing Stop ---
    stop1 = StdDevTrailingStop(stopper=252, stopfactor=12.0)
    stop1.update(df, 400, position=1)
    print(f"\n1. StdDev Trailing Stop price:  {stop1.get_stop_price():.4f}")

    # --- 2. ATR Trailing Stop ---
    stop2 = ATRTrailingStop(atr_period=20, stopfactor=2.5, trigger=2.0)
    stop2.set_entry(df['close'].iloc[300])
    for i in range(300, 400):
        stop2.update(df, i, position=1)
    print(f"2. ATR Trailing Stop price:     {stop2.get_stop_price()}")

    # --- 3. DevStop ---
    stop3 = DevStop(atr_period=20)
    stop3.set_entry(df, 300, position=1, num_contracts=3)
    prices = stop3.get_stop_prices()
    print(f"3. DevStop levels:              "
          f"L1={prices['dev_stop1']:.4f}  "
          f"L2={prices['dev_stop2']:.4f}  "
          f"L3={prices['dev_stop3']:.4f}")

    # --- 4. Volatility Spike Exit ---
    stop4 = VolatilitySpikeExit(vol_period=20, exitabove=5.0)
    triggered = stop4.check_stop(df, 400, position=1)
    print(f"4. Volatility Spike triggered:  {triggered}")

    # --- 5. Volatility Filter Exit ---
    stop5 = VolatilityFilterExit(rule=4, length=20, x_factor=2.0)
    triggered = stop5.check_stop(df, 400, position=1)
    print(f"5. Vol Filter (rule 4) triggered: {triggered}")

    # --- 6. VIX Filter Stop ---
    stop6 = VIXFilterStop(risk_option=0, vol_period=20,
                          risk_exit_threshold=50.0)
    triggered = stop6.check_stop(df, 400, position=1, trend_rising=True)
    print(f"6. VIX Filter triggered:        {triggered}")

    # --- 7. Annualized Vol Stop ---
    stop7 = AnnualizedVolStop(vol_period=20, risk_exit_threshold=0.50)
    triggered = stop7.check_stop(df, 400, position=1)
    print(f"7. Annualized Vol triggered:    {triggered}")

    # --- 8. Historic Vol Stop ---
    stop8 = HistoricVolStop(risk_option=0, vol_period=20,
                            risk_exit_threshold=0.60)
    triggered = stop8.check_stop(df, 400, position=1)
    print(f"8. Historic Vol triggered:      {triggered}")

    # --- 9. Equity Curve Stop ---
    stop9 = EquityCurveStop(eq_length=10, normal_size=10, reduce_pct=50)
    for i in range(50):
        stop9.update(10000 - i * 50)  # declining equity
    target = stop9.get_target_size()
    print(f"9. Equity Curve target size:    {target} (normal=10)")

